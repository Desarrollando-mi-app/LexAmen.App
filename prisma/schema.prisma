// ─── Noticias Jurídicas ──────────────────────────────────

model NoticiaJuridica {
  id String @id @default(cuid())

  titulo       String
  resumen      String?
  contenido    String? // Cuerpo completo (cartas al director / columnas / editoriales)
  urlFuente    String  @unique
  fuente       String
  fuenteNombre String

  categoria String?
  rama      String?

  imagenUrl String?

  estado    String  @default("pendiente")
  destacada Boolean @default(false)

  fechaPublicacionFuente DateTime?
  fechaRecopilacion      DateTime  @default(now())
  fechaAprobacion        DateTime?

  // Archivo automático tras TTL (48h desde fechaAprobacion) — cron nocturno
  // flippea archivada=true, fechaArchivo=now(). Las queries públicas también
  // filtran por tiempo para precisión a la minuto sin esperar al cron.
  archivada    Boolean   @default(false)
  fechaArchivo DateTime?

  // ─── Pinning (V4) ───
  // pinnedUntil: cartas/columnas → 7 días arriba del feed.
  // pinnedTop:   editoriales → arriba hasta que el admin retire o publique nueva.
  pinnedUntil DateTime?
  pinnedTop   Boolean   @default(false)

  aprobadaPor String?
  notasAdmin  String?

  tituloSugerido   String? // Título descriptivo generado por IA
  motivoLey        String? // Por qué se ingresa/publica (solo para nueva_ley)
  numeroLey        String? // "21.680" — extraído por IA
  leyesModificadas String? // "Modifica Ley 19.496, deroga arts. 3-5 Ley 20.169"
  comentarioAdmin  String? // Explicación redactada por admin al aprobar

  comentarios NoticiaComentario[]
  guardados   NoticiaGuardada[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estado, fechaAprobacion])
  @@index([estado, archivada, fechaAprobacion])
  @@index([fuente, fechaRecopilacion])
  @@index([destacada, estado])
  @@index([pinnedTop, pinnedUntil])
}

model NoticiaComentario {
  id        String          @id @default(cuid())
  noticiaId String
  noticia   NoticiaJuridica @relation(fields: [noticiaId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation("NoticiaComentarios", fields: [userId], references: [id], onDelete: Cascade)
  contenido String
  createdAt DateTime        @default(now())

  @@index([noticiaId, createdAt])
}

model NoticiaGuardada {
  id        String          @id @default(cuid())
  noticiaId String
  noticia   NoticiaJuridica @relation(fields: [noticiaId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation("NoticiasGuardadas", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@unique([noticiaId, userId])
}

