  CONTROVERSIA
  DOCTRINARIO
  ENSAYISTA
  PLUMA_NOVEL
  TRATADISTA
  VOZ_DEL_FORO
  // Expediente Abierto
  PRIMER_ALEGATO_EXPEDIENTE
  MEJOR_ALEGATO
  JURISTA_DE_EXPEDIENTES
  // Peer Review + Ranking
