// ─── Mi Examen (Plan de Estudio Personalizado) ───────────

model ExamenConfig {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Datos del examen
  universidad String
  sede        String?
  fechaExamen DateTime?

  // Cedulario original
  cedularioTexto  String?
  cedularioUrl    String?
  cedularioSource String? // "text" | "pdf"

  // Estado del parsing
  parseStatus String    @default("pending") // "pending" | "parsing" | "completed" | "error"
  parseError  String?
  parsedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  temas ExamenTema[]

  @@index([userId])
}

model ExamenTema {
  id             String       @id @default(uuid())
  examenConfigId String
  examenConfig   ExamenConfig @relation(fields: [examenConfigId], references: [id], onDelete: Cascade)

  // Datos del tema extraído del cedulario
  nombre            String
  descripcion       String?
  categoriaOriginal String?

  // Mapeo al contenido de Studio Iuris
  materiaMapping String? // Valor de rama que corresponde: "DERECHO_CIVIL", "DERECHO_PROCESAL_CIVIL"
  libroMapping   String? // Valor de libro si hay match más granular
  tituloMapping  String? // Valor de titulo si hay match aún más específico

  // Disponibilidad de contenido
  flashcardsDisponibles Int     @default(0)
  mcqDisponibles        Int     @default(0)
  vfDisponibles         Int     @default(0)
  tieneContenido        Boolean @default(false)

  // Progreso del usuario (se actualiza periódicamente)
  flashcardsDominadas Int   @default(0)
  mcqCorrectas        Int   @default(0)
  vfCorrectas         Int   @default(0)
  porcentajeAvance    Float @default(0) // 0-100

  // Orden y peso
  orden Int   @default(0)
  peso  Float @default(1.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([examenConfigId])
  @@index([materiaMapping])
}

model ExamenReporte {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  universidad String
  fechaExamen DateTime
  aprobado    Boolean?

  materiasPreguntadas String // JSON: ["obligaciones", "procesal_civil", ...]

  comentario          String?
  dificultadPercibida Int? // 1-5

  createdAt DateTime @default(now())

  @@index([universidad])
  @@index([createdAt(sort: Desc)])
}

// ─── Definiciones ─────────────────────────────────────────

model Definicion {
  id String @id @default(cuid())

  concepto         String
  definicion       String
  rama             Rama
  ramasAdicionales Rama[]  @default([])
  libro            String?
  titulo           String?
  parrafo          String?

  distractor1 String
  distractor2 String
  distractor3 String

  explicacion String?
  articuloRef String?

  // ─── Fase 2: flags de reorganización ───
  esIntegrador     Boolean @default(false)
  sourceExerciseId String?

  institucionId Int?
  institucion   InstitucionJuridica? @relation(fields: [institucionId], references: [id])

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  intentos DefinicionIntento[]

  @@index([rama])
  @@index([isActive, rama])
  @@index([rama, libro, titulo, parrafo])
  @@index([esIntegrador])
  @@index([sourceExerciseId])
  @@index([institucionId])
}

model DefinicionIntento {
  id           String     @id @default(cuid())
  definicionId String
  definicion   Definicion @relation(fields: [definicionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation("DefinicionIntentos", fields: [userId], references: [id], onDelete: Cascade)

  respuesta String
  correcta  Boolean
  tiempoMs  Int?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([definicionId])
  @@index([userId, createdAt(sort: Desc)])
}

// ─── XP Log — Desglose por categoría ────────────────────────

model XpLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("XpLogs", fields: [userId], references: [id], onDelete: Cascade)
  amount    Int // Puede ser negativo (penalización)
  category  String // "estudio" | "simulacro" | "causas" | "publicaciones" | "bonus"
  detalle   String? // "MCQ", "Flashcards", "V/F", "Definiciones", "Simulacro Oral", etc.
  materia   String? // "Derecho Civil", "Procesal Civil", etc. (si aplica)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, category])
  @@index([userId, createdAt(sort: Desc)])
}

// ═══ SPONSORS ════════════════════════════════════════════════════

model SponsorBanner {
  id          String    @id @default(uuid())
  nombre      String // Nombre del sponsor (interno)
  titulo      String? // Texto principal del banner
  descripcion String? // Texto secundario
  imagenUrl   String? // URL de la imagen del banner
  linkUrl     String? // URL destino al hacer click
  posicion    String    @default("lateral") // "principal" | "lateral" | "footer"
  activo      Boolean   @default(true)
  fechaInicio DateTime  @default(now())
  fechaFin    DateTime? // null = indefinido
  clicks      Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([activo, posicion])
  @@index([fechaInicio, fechaFin])
}

// ─── Plan de Estudios ──────────────────────────────────────

model PlanEstudio {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation("PlanEstudio", fields: [userId], references: [id])

  // PDFs subidos (hasta 3)
  pdf1Url    String?
  pdf1Nombre String?
  pdf1Texto  String?
  pdf2Url    String?
  pdf2Nombre String?
  pdf2Texto  String?
  pdf3Url    String?
  pdf3Nombre String?
  pdf3Texto  String?

  // Configuración
  fechaExamen     DateTime
  horasEstudioDia Int      @default(3)
  diasDescanso    String   @default("[]") // JSON: ["domingo"]
  modoGeneracion  String   @default("automatico") // "automatico" | "manual"

  // Estado
  estado String @default("configurando") // configurando | generando | activo | completado

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  temas    PlanTema[]
  sesiones PlanSesionDiaria[]
}

model PlanTema {
  id     String      @id @default(uuid())
  planId String
  plan   PlanEstudio @relation(fields: [planId], references: [id], onDelete: Cascade)

  // Vinculación al Índice Maestro
  rama    String // "DERECHO_CIVIL" | "DERECHO_PROCESAL_CIVIL" | "DERECHO_ORGANICO"
  libro   String?
  titulo  String
  parrafo String?

  // Metadata
  nombre          String
  prioridad       Int    @default(2) // 1=alta, 2=media, 3=baja
  estimacionHoras Float  @default(1)

  // Progreso
  completado Boolean @default(false)
  porcentaje Float   @default(0) // 0-100

  createdAt DateTime @default(now())

  @@index([planId])
  @@index([planId, rama])
}

model PlanSesionDiaria {
  id     String      @id @default(uuid())
  planId String
  plan   PlanEstudio @relation(fields: [planId], references: [id], onDelete: Cascade)

  fecha       DateTime
  actividades String   @default("[]") // JSON: [{ temaId, temaNombre, actividad, duracionMin }]

  completada Boolean @default(false)
  xpGanado   Int     @default(0)

  calendarEventId String?

  createdAt DateTime @default(now())

  @@unique([planId, fecha])
  @@index([planId, fecha])
}

// ─── Completar Espacios en Blanco ─────────────────────────

model FillBlank {
  id String @id @default(cuid())

  textoConBlancos String // "El artículo {1} del CC establece que {2}..."
  blancos         String // JSON: [{ id: 1, correcta: "...", opciones: [...] }]
  explicacion     String?

  rama             String
  ramasAdicionales String[] @default([])
  libro            String?
  titulo           String?
  parrafo          String?
  materia          String?
  dificultad       Int      @default(2)

  // ─── Fase 2: flags de reorganización ───
  esIntegrador     Boolean @default(false)
  sourceExerciseId String?

  institucionId Int?
  institucion   InstitucionJuridica? @relation(fields: [institucionId], references: [id])

  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  attempts FillBlankAttempt[]

  @@index([rama, activo])
  @@index([rama, libro, titulo, parrafo])
  @@index([esIntegrador])
  @@index([sourceExerciseId])
  @@index([institucionId])
}

model FillBlankAttempt {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("FillBlankAttempts", fields: [userId], references: [id], onDelete: Cascade)
  fillBlankId String
  fillBlank   FillBlank @relation(fields: [fillBlankId], references: [id], onDelete: Cascade)

  respuestas     String // JSON: [{ blancoId: 1, respuesta: "...", correcta: true }]
  todosCorrectos Boolean

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ─── Identificar Errores ──────────────────────────────────

model ErrorIdentification {
  id String @id @default(cuid())

  textoConErrores    String
  segmentos          String // JSON: [{ id: 0, texto: "...", esError: false }, { id: 1, texto: "condición resolutoria", esError: true, textoCorrecto: "...", explicacion: "..." }]
  totalErrores       Int
  explicacionGeneral String?

  rama             String
  ramasAdicionales String[] @default([])
  libro            String?
  titulo           String?
  parrafo          String?
  materia          String?
  dificultad       Int      @default(2)

  // ─── Fase 2: flags de reorganización ───
  esIntegrador     Boolean @default(false)
  sourceExerciseId String?

  institucionId Int?
  institucion   InstitucionJuridica? @relation(fields: [institucionId], references: [id])

  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  attempts ErrorIdentificationAttempt[]

  @@index([rama, activo])
  @@index([rama, libro, titulo, parrafo])
  @@index([esIntegrador])
  @@index([sourceExerciseId])
  @@index([institucionId])
}

model ErrorIdentificationAttempt {
  id                    String              @id @default(cuid())
  userId                String
  user                  User                @relation("ErrorIdAttempts", fields: [userId], references: [id], onDelete: Cascade)
  errorIdentificationId String
  errorIdentification   ErrorIdentification @relation(fields: [errorIdentificationId], references: [id], onDelete: Cascade)

  selecciones     String // JSON: [{ segmentoId: 1, seleccionado: true }]
  aciertos        Int
  fallosPositivos Int

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ─── Ordenar Secuencias ───────────────────────────────────

model OrderSequence {
  id String @id @default(cuid())

  titulo      String
  instruccion String?
  items       String // JSON: [{ id: 1, texto: "...", orden: 1 }, ...]
  explicacion String?

  rama             String
  ramasAdicionales String[] @default([])
  libro            String?
  tituloMateria    String?
  parrafo          String?
  materia          String?
  dificultad       Int      @default(2)

  // ─── Fase 2: flags de reorganización ───
  esIntegrador     Boolean @default(false)
  sourceExerciseId String?

  institucionId Int?
  institucion   InstitucionJuridica? @relation(fields: [institucionId], references: [id])

  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  attempts OrderSequenceAttempt[]

