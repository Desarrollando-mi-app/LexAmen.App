  motivo      String // "spam" | "contenido_ofensivo" | "plagio" | "acoso" | "informacion_falsa" | "otro"
  descripcion String?

  estado      String    @default("pendiente") // "pendiente" | "revisado" | "accion_tomada" | "descartado"
  resolucion  String?
  resueltoPor String?
  resueltaAt  DateTime?

  createdAt DateTime @default(now())

  @@index([estado, createdAt])
  @@index([reportadoId])
}

