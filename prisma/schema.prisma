// Iuris Studio — Schema de base de datos
// Plataforma de aprendizaje de Derecho Civil y Procesal Civil (Chile)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Plan {
  FREE
  PREMIUM_MONTHLY
  PREMIUM_ANNUAL
}

enum Rama {
  DERECHO_CIVIL
  DERECHO_PROCESAL_CIVIL
  DERECHO_ORGANICO
}

enum Codigo {
  CODIGO_CIVIL
  CODIGO_PROCEDIMIENTO_CIVIL
  CODIGO_ORGANICO_TRIBUNALES
  LEY_ANEXA
}

enum Libro {
  TITULO_PRELIMINAR
  MENSAJE
  LIBRO_I
  LIBRO_II
  LIBRO_III
  LIBRO_IV
  TITULO_FINAL
  LIBRO_I_CPC
  LIBRO_II_CPC
  LIBRO_III_CPC
  LIBRO_IV_CPC
  LIBRO_COT
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum LeagueTier {
  CARTON
  HIERRO
  BRONCE
  COBRE
  PLATA
  ORO
  DIAMANTE
  PLATINO
  JURISCONSULTO
}

enum CausaStatus {
  PENDING
  ACTIVE
  COMPLETED
  REJECTED
  EXPIRED
}

