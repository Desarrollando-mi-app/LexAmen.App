// ─── El Diario (Publicacion Academica) ─────────────────

model DiarioPost {
  id            String              @id @default(cuid())
  userId        String
  formato       DiarioFormato
  visibilidad   DiarioVisibilidad   @default(PUBLICO)
  titulo        String
  materia       String?
  // Obiter Dictum
  contenido     String?
  // Analisis de Fallos
  rol           String?
  tribunal      String?
  fecha         String?
  partes        String?
  hechos        String?
  ratio         String?
  norma         String?
  opinion       String?
  pdfUrl        String?
  // Metricas
  views         Int                 @default(0)
  // Citas (self-relation)
  citadoDeId    String?
  citadoDe      DiarioPost?         @relation("Citas", fields: [citadoDeId], references: [id], onDelete: SetNull)
  citas         DiarioPost[]        @relation("Citas")
  // Relations
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashtags      DiarioPostHashtag[]
  guardados     DiarioGuardado[]
