}

model DiarioHashtag {
  id             String              @id @default(cuid())
  tag            String              @unique
  count          Int                 @default(0)
  isContingencia Boolean             @default(false)
  pinned         Boolean             @default(false)
  hidden         Boolean             @default(false)
