  @@index([createdAt])
}

model SimulacroPregunta {
  id                  String            @id @default(cuid())
  sesionId            String
  numero              Int
  nivel               NivelDificultad
  preguntaTexto       String
  respuestaUser       String?
  evaluacion          String?
  correcta            Boolean?
  intercambioTexto    String?           // Texto del intercambio (aclaración o repregunta)
  respuestaIntercambio String?          // Segunda respuesta del usuario
  tipoIntercambio     String?           // "aclaracion" | "repregunta" | null
  sesion              SimulacroSesion   @relation(fields: [sesionId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
}

// ─── Hero Carrusel & Anunciantes ─────────────────────────

