  ensayoId  String
  ensayo    Ensayo   @relation(fields: [ensayoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("EnsayoGuardados", fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([ensayoId, userId])
