// Iuris Studio — Schema de base de datos
// Plataforma de aprendizaje de Derecho Civil y Procesal Civil (Chile)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Plan {
  FREE
  PREMIUM_MONTHLY
  PREMIUM_ANNUAL
}

enum Rama {
  DERECHO_CIVIL
  DERECHO_PROCESAL_CIVIL
}

enum Codigo {
  CODIGO_CIVIL
  CODIGO_PROCEDIMIENTO_CIVIL
  LEY_ANEXA
}

enum Libro {
  TITULO_PRELIMINAR
  MENSAJE
  LIBRO_I
  LIBRO_II
  LIBRO_III
  LIBRO_IV
  TITULO_FINAL
  LIBRO_I_CPC
  LIBRO_II_CPC
  LIBRO_III_CPC
  LIBRO_IV_CPC
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum LeagueTier {
  CARTON
  HIERRO
  BRONCE
  COBRE
  PLATA
  ORO
  DIAMANTE
  PLATINO
  JURISCONSULTO
}

enum CausaStatus {
  PENDING
  ACTIVE
  COMPLETED
  REJECTED
  EXPIRED
}

enum BadgeSlug {
  PASANTE
  PROCURADOR
  ABOGADO_LITIGANTE
  PENALISTA_EN_SERIE
  JURISCONSULTO_SEMANA
  SOCIEDAD_DE_HECHO
}

enum NotificationType {
  SYSTEM_BROADCAST
  SYSTEM_SEGMENTED
  SYSTEM_INDIVIDUAL
  LEAGUE_RESULT
  CAUSA_FINISHED
  NEW_CONTENT
  BADGE_EARNED
  COLEGA_REQUEST
  COLEGA_ACCEPTED
  CV_REQUEST
  CV_REQUEST_ACCEPTED
}

enum ColegaStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum AyudantiaType {
  OFREZCO
  BUSCO
}

enum AyudantiaFormat {
  ONLINE
  PRESENCIAL
  AMBOS
}

enum PriceType {
  GRATUITO
  PAGADO
}

enum ContactMethod {
  WHATSAPP
  EMAIL
  OTRO
}

enum DiarioFormato {
  OBITER_DICTUM
  ANALISIS_FALLOS
}

enum DiarioVisibilidad {
  PUBLICO
  COLEGAS
}

enum TipoInstitucion {
  FACULTAD_DERECHO
  ESTUDIO_JURIDICO
  CENTRO_INVESTIGACION
  OTRO
}

// ─── Modelos ─────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  firstName       String
  lastName        String
  age             Int?
  gender          String?
  institution     String?
  universidad     String?
  sede            String?
  universityYear  Int?
  plan            Plan      @default(FREE)
  planExpiresAt   DateTime?
  termsAcceptedAt DateTime?
  termsVersion    String?
  examDate        DateTime?
  bio             String?
  avatarUrl       String?
  cvAvailable     Boolean   @default(false)
  deletedAt       DateTime?
  xp              Int       @default(0)
  causasGanadas   Int       @default(0)
  causasPerdidas  Int       @default(0)
  suspended       Boolean   @default(false)
  isAdmin         Boolean   @default(false)
  createdAt       DateTime  @default(now())

  flashcardProgress   UserFlashcardProgress[]
  flashcardFavorites  FlashcardFavorite[]
  mcqAttempts         UserMCQAttempt[]
  trueFalseAttempts   UserTrueFalseAttempt[]
  contentReports      ContentReport[]
  curriculumProgress  CurriculumProgress[]
  leagueMembers       LeagueMember[]
  causasRetadas       Causa[]        @relation("CausasRetadas")
  causasRecibidas     Causa[]        @relation("CausasRecibidas")
  causasGanadasRel    Causa[]        @relation("CausasGanadas")
  causaAnswers        CausaAnswer[]
  badges              UserBadge[]
  causaRoomsCreated   CausaRoom[]          @relation("CausaRoomsCreated")
  causaParticipations CausaParticipant[]
  causaRoomAnswers    CausaRoomAnswer[]
  subscriptions       Subscription[]
  ayudantias          Ayudantia[]
  ayudantiaReports    AyudantiaReport[]
  ayudantiaStreak     AyudantiaStreak?
  notifications       UserNotification[]
  colegasSent         ColegaRequest[] @relation("ColegasSent")
  colegasReceived     ColegaRequest[] @relation("ColegasReceived")
  calendarEvents      CalendarEvent[]
  cvRequestsSent      CvRequest[]     @relation("CvRequestsSent")
  cvRequestsReceived  CvRequest[]     @relation("CvRequestsReceived")
  adminLogs           AdminLog[]
  diarioPosts         DiarioPost[]
  diarioGuardados     DiarioGuardado[]
}

model Flashcard {
  id          String  @id @default(cuid())
  front       String
  back        String
  rama        Rama
  codigo      Codigo
  libro       Libro
  titulo      String
  parrafo     String?
  leyAnexa    String?
  articuloRef String?
  dificultad  String  @default("BASICO")

  progress  UserFlashcardProgress[]
  favorites FlashcardFavorite[]

  @@index([rama, libro])
}

model UserFlashcardProgress {
  id             String    @id @default(cuid())
  userId         String
  flashcardId    String
  easeFactor     Float     @default(2.5)
  interval       Int       @default(0)
  repetitions    Int       @default(0)
  nextReviewAt   DateTime  @default(now())
  lastReviewedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
}

model MCQ {
  id            String  @id @default(cuid())
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String
  explanation   String?
  rama          Rama
  codigo        Codigo
  libro         Libro
  titulo        String
  parrafo       String?
  leyAnexa      String?
  articuloRef   String?
  dificultad    String  @default("BASICO")

  attempts           UserMCQAttempt[]
  causaAnswers       CausaAnswer[]
  causaRoomQuestions CausaRoomQuestion[]
  causaRoomAnswers   CausaRoomAnswer[]

  @@index([rama, libro])
}

model UserMCQAttempt {
  id             String   @id @default(cuid())
  userId         String
  mcqId          String
  selectedOption String
  isCorrect      Boolean
  attemptedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcq  MCQ  @relation(fields: [mcqId], references: [id], onDelete: Cascade)
}

model TrueFalse {
  id          String  @id @default(cuid())
  statement   String
  isTrue      Boolean
  explanation String?
  rama        Rama
  codigo      Codigo
  libro       Libro
  titulo      String
  parrafo     String?
  leyAnexa    String?
  articuloRef String?
  dificultad  String  @default("BASICO")

  attempts UserTrueFalseAttempt[]

  @@index([rama, libro])
}

model UserTrueFalseAttempt {
  id             String   @id @default(cuid())
  userId         String
  trueFalseId    String
  selectedAnswer Boolean
  isCorrect      Boolean
  attemptedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trueFalse TrueFalse @relation(fields: [trueFalseId], references: [id], onDelete: Cascade)
}

model ContentReport {
  id          String   @id @default(cuid())
  userId      String
  contentType String
  contentId   String
  reason      String
  description String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CurriculumProgress {
  id              String    @id @default(cuid())
  userId          String
  rama            Rama
  libro           Libro
  titulo          String
  completions     Int       @default(0)
  lastCompletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, rama, libro, titulo])
}

// ─── Ligas Semanales ─────────────────────────────────────

model League {
  id        String     @id @default(cuid())
  tier      LeagueTier
  weekStart DateTime
  weekEnd   DateTime
  createdAt DateTime   @default(now())

  members LeagueMember[]

  @@index([tier, weekStart])
}

model LeagueMember {
  id       String @id @default(cuid())
  userId   String
  leagueId String
  weeklyXp Int    @default(0)
  rank     Int?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
  @@index([leagueId, weeklyXp])
}

// ─── Causas (Duelos 1v1) ────────────────────────────────

model Causa {
  id           String      @id @default(cuid())
  challengerId String
  challengedId String
  status       CausaStatus @default(PENDING)
  winnerId     String?
  createdAt    DateTime    @default(now())
  startedAt    DateTime?
  completedAt  DateTime?

  challenger User  @relation("CausasRetadas", fields: [challengerId], references: [id], onDelete: Cascade)
  challenged User  @relation("CausasRecibidas", fields: [challengedId], references: [id], onDelete: Cascade)
  winner     User? @relation("CausasGanadas", fields: [winnerId], references: [id], onDelete: SetNull)

  answers CausaAnswer[]

  @@index([challengerId, status])
  @@index([challengedId, status])
}

model CausaAnswer {
  id             String   @id @default(cuid())
  causaId        String
  userId         String
  mcqId          String
  questionIdx    Int
  selectedOption String?
  isCorrect      Boolean?
  timeMs         Int?
  score          Int      @default(0)
  answeredAt     DateTime @default(now())

  causa Causa @relation(fields: [causaId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcq   MCQ   @relation(fields: [mcqId], references: [id], onDelete: Cascade)

  @@unique([causaId, userId, questionIdx])
}

// ─── Insignias ───────────────────────────────────────────

model UserBadge {
  id       String    @id @default(cuid())
  userId   String
  badge    BadgeSlug
  earnedAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badge])
}

// ─── CausaRoom (Causa Grupal / Multiplayer) ──────────────

model CausaRoom {
  id               String   @id @default(cuid())
  mode             String   @default("individual")
  status           String   @default("lobby")
  maxPlayers       Int      @default(10)
  createdById      String
  rama             String?
  difficulty       String?
  timeLimitSeconds Int      @default(30)
  createdAt        DateTime @default(now())

  createdBy    User                @relation("CausaRoomsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  participants CausaParticipant[]
  questions    CausaRoomQuestion[]
  answers      CausaRoomAnswer[]

  @@index([status])
}

model CausaParticipant {
  roomId   String
  userId   String
  score    Int      @default(0)
  position Int?
  joinedAt DateTime @default(now())

  room CausaRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
}

model CausaRoomQuestion {
  id            String @id @default(cuid())
  roomId        String
  mcqId         String
  questionIndex Int

  room CausaRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  mcq  MCQ       @relation(fields: [mcqId], references: [id], onDelete: Cascade)

  @@unique([roomId, questionIndex])
}

model CausaRoomAnswer {
  id             String   @id @default(cuid())
  roomId         String
  userId         String
  mcqId          String
  questionIndex  Int
  selectedOption String?
  isCorrect      Boolean?
  timeMs         Int?
  score          Int      @default(0)
  answeredAt     DateTime @default(now())

  room CausaRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcq  MCQ       @relation(fields: [mcqId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId, questionIndex])
}

// ─── Flashcard Favoritos ─────────────────────────────────

model FlashcardFavorite {
  id          String   @id @default(cuid())
  userId      String
  flashcardId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
}

// ─── La Sala (Ayudantías) ─────────────────────────────────

model Ayudantia {
  id            String          @id @default(cuid())
  userId        String
  type          AyudantiaType
  materia       String
  format        AyudantiaFormat
  priceType     PriceType
  priceAmount   Int?
  description   String
  universidad   String
  orientadaA    String[]
  contactMethod ContactMethod
  contactValue  String
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  reportCount   Int             @default(0)

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports AyudantiaReport[]

  @@index([type, isActive])
  @@index([userId])
}

model AyudantiaReport {
  id           String   @id @default(cuid())
  ayudantiaId  String
  reportedById String
  reason       String
  createdAt    DateTime @default(now())

  ayudantia  Ayudantia @relation(fields: [ayudantiaId], references: [id], onDelete: Cascade)
  reportedBy User      @relation(fields: [reportedById], references: [id])

  @@unique([ayudantiaId, reportedById])
}

model AyudantiaStreak {
  userId          String @id
  monthsActive    Int    @default(0)
  lastActiveMonth String
  longestStreak   Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Notificaciones ─────────────────────────────────────

model Notification {
  id            String           @id @default(cuid())
  type          NotificationType
  title         String
  body          String
  senderId      String?
  targetUserId  String?
  targetSegment String?
  metadata      Json?
  sentViaEmail  Boolean          @default(false)
  createdAt     DateTime         @default(now())

  userNotifications UserNotification[]
}

model UserNotification {
  id             String    @id @default(cuid())
  userId         String
  notificationId String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ─── Colegas (Amigos) ────────────────────────────────────

model ColegaRequest {
  id         String       @id @default(cuid())
  senderId   String
  receiverId String
  status     ColegaStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  sender   User @relation("ColegasSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ColegasReceived", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
}

// ─── Calendario Personal ──────────────────────────────────

model CalendarEvent {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  eventType   String   @default("personal")
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean  @default(false)
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
}

// ─── Solicitudes de CV ─────────────────────────────────

model CvRequest {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  message    String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  fromUser User @relation("CvRequestsSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("CvRequestsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
}

// ─── Admin Logs ─────────────────────────────────────────

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([action, createdAt])
}

// ─── Suscripciones ──────────────────────────────────────

model Subscription {
  id             String             @id @default(cuid())
  userId         String
  plan           Plan
  amount         Int
  currency       String             @default("CLP")
  status         SubscriptionStatus @default(PENDING)
  transbankToken String?
  createdAt      DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── El Diario (Publicacion Academica) ─────────────────

model DiarioPost {
  id            String              @id @default(cuid())
  userId        String
  formato       DiarioFormato
  visibilidad   DiarioVisibilidad   @default(PUBLICO)
  titulo        String
  materia       String?
  // Obiter Dictum
  contenido     String?
  // Analisis de Fallos
  rol           String?
  tribunal      String?
  fecha         String?
  partes        String?
  hechos        String?
  ratio         String?
  norma         String?
  opinion       String?
  pdfUrl        String?
  // Metricas
  views         Int                 @default(0)
  // Citas (self-relation)
  citadoDeId    String?
  citadoDe      DiarioPost?         @relation("Citas", fields: [citadoDeId], references: [id], onDelete: SetNull)
  citas         DiarioPost[]        @relation("Citas")
  // Relations
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashtags      DiarioPostHashtag[]
  guardados     DiarioGuardado[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId, createdAt])
  @@index([formato, createdAt])
}

model DiarioHashtag {
  id             String              @id @default(cuid())
  tag            String              @unique
  count          Int                 @default(0)
  isContingencia Boolean             @default(false)
  pinned         Boolean             @default(false)
  hidden         Boolean             @default(false)
  posts          DiarioPostHashtag[]
  createdAt      DateTime            @default(now())
}

model DiarioPostHashtag {
  postId    String
  hashtagId String
  post      DiarioPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag   DiarioHashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
}

model DiarioGuardado {
  id        String     @id @default(cuid())
  userId    String
  postId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      DiarioPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([userId, postId])
}

// ─── Plan Institucional ──────────────────────────────────

model RegistroInteres {
  id                String           @id @default(cuid())
  nombreInstitucion String
  tipoInstitucion   TipoInstitucion
  nombreContacto    String
  emailContacto     String
  telefono          String?
  mensaje           String?
  createdAt         DateTime         @default(now())

  @@index([createdAt])
  @@index([tipoInstitucion])
}
