enum NotificationType {
  SYSTEM_BROADCAST
  SYSTEM_SEGMENTED
  SYSTEM_INDIVIDUAL
  LEAGUE_RESULT
  CAUSA_FINISHED
  NEW_CONTENT
  BADGE_EARNED
  COLEGA_REQUEST
  COLEGA_ACCEPTED
  CV_REQUEST
  CV_REQUEST_ACCEPTED
  OBITER_APOYO
  OBITER_CITA
  OBITER_COMUNIQUESE
  ANALISIS_APOYO
  ANALISIS_COMUNIQUESE
  ENSAYO_APOYO
  ENSAYO_COMUNIQUESE
  EVENTO_INTERES
}

enum ColegaStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum AyudantiaType {
  OFREZCO
  BUSCO
}

enum AyudantiaFormat {
  ONLINE
  PRESENCIAL
  AMBOS
}

enum PriceType {
  GRATUITO
  PAGADO
}

enum ContactMethod {
  WHATSAPP
  EMAIL
  OTRO
}

enum DiarioFormato {
  OBITER_DICTUM
  ANALISIS_FALLOS
}

enum DiarioVisibilidad {
  PUBLICO
  COLEGAS
}

enum TipoInstitucion {
  FACULTAD_DERECHO
  ESTUDIO_JURIDICO
  CENTRO_INVESTIGACION
  OTRO
}

enum FuenteSimulacro {
  APUNTES_PROPIOS
  INDICE_MAESTRO
}

enum InterrogadorId {
  DON_AUGUSTO
  PROFESORA_VALERIA
  EL_MINISTRO
  COLEGA_MAYOR
  COMPANERO_CLASES
}

enum NivelDificultad {
  BASICO
  INTERMEDIO
  AVANZADO
}

enum SlideOrigen {
  editorial
  publicitario
}

enum SlideEstado {
  borrador
  aprobado
  activo
  pausado
  finalizado
}

// ─── Modelos ─────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  firstName       String
  lastName        String
  age             Int?
  gender          String?
  institution     String?
  universidad     String?
  sede            String?
  universityYear  Int?
  plan            Plan      @default(FREE)
  planExpiresAt   DateTime?
  termsAcceptedAt DateTime?
  termsVersion    String?
  examDate        DateTime?
  bio             String?
  etapaActual     String?   // "estudiante" | "egresado" | "abogado"
  anioIngreso     Int?
  anioEgreso      Int?
  anioJura        Int?
  empleoActual    String?
  cargoActual     String?
  especialidades  String?   // JSON array stored as string
  intereses       String?   // JSON array stored as string
  linkedinUrl     String?
  avatarUrl       String?
  cvAvailable     Boolean   @default(false)
  region          String?   // "Región Metropolitana de Santiago", etc.
  corte           String?   // "Santiago", "Valparaíso", etc. (comuna sede de Corte)
  visibleEnRanking Boolean  @default(true)
  visibleEnLiga    Boolean  @default(true)
  deletedAt       DateTime?
  xp              Int       @default(0)
  grado           Int       @default(1)
  causasGanadas   Int       @default(0)
  causasPerdidas  Int       @default(0)
  suspended       Boolean   @default(false)
  isAdmin         Boolean   @default(false)
  createdAt       DateTime  @default(now())

  flashcardProgress   UserFlashcardProgress[]
  flashcardFavorites  FlashcardFavorite[]
  mcqAttempts         UserMCQAttempt[]
  trueFalseAttempts   UserTrueFalseAttempt[]
  contentReports      ContentReport[]
  curriculumProgress  CurriculumProgress[]
  leagueMembers       LeagueMember[]
  causasRetadas       Causa[]        @relation("CausasRetadas")
  causasRecibidas     Causa[]        @relation("CausasRecibidas")
  causasGanadasRel    Causa[]        @relation("CausasGanadas")
  causaAnswers        CausaAnswer[]
  badges              UserBadge[]
  causaRoomsCreated   CausaRoom[]          @relation("CausaRoomsCreated")
  causaParticipations CausaParticipant[]
  causaRoomAnswers    CausaRoomAnswer[]
  subscriptions       Subscription[]
  ayudantias              Ayudantia[]           @relation("AyudantiasCreadas")
  ayudantiaReports        AyudantiaReport[]
  ayudantiaStreak         AyudantiaStreak?
  sesionesTutor           AyudantiaSesion[]     @relation("SesionesTutor")
  sesionesEstudiante      AyudantiaSesion[]     @relation("SesionesEstudiante")
  evaluacionesDadas       AyudantiaEvaluacion[] @relation("EvaluacionesDadas")
  evaluacionesRecibidas   AyudantiaEvaluacion[] @relation("EvaluacionesRecibidas")
  pasantiasCreadas        Pasantia[]            @relation("PasantiasCreadas")
  eventosCreados          EventoAcademico[]     @relation("EventosCreados")
  eventosInteres          EventoInteres[]       @relation("EventosInteres")
  ofertasCreadas          OfertaTrabajo[]       @relation("OfertasCreadas")
  reportesSalaCreados     SalaReporte[]         @relation("ReportesCreados")
  notifications       UserNotification[]
  colegasSent         ColegaRequest[] @relation("ColegasSent")
  colegasReceived     ColegaRequest[] @relation("ColegasReceived")
  calendarEvents      CalendarEvent[]
  countdowns          UserCountdown[]    @relation("UserCountdowns")
  cvRequestsSent      CvRequest[]     @relation("CvRequestsSent")
  cvRequestsReceived  CvRequest[]     @relation("CvRequestsReceived")
  adminLogs           AdminLog[]
  diarioPosts         DiarioPost[]
  diarioGuardados     DiarioGuardado[]
  simulacroSesiones   SimulacroSesion[]
  simulacroReportes   SimulacroReporte[]
  heroSlideEventos    HeroSlideEvento[]
  obiters             ObiterDictum[]
  obiterApoyos        ObiterApoyo[]
  obiterGuardados     ObiterGuardado[]
  examenConfig        ExamenConfig?
  examenReportes      ExamenReporte[]
  planEstudio         PlanEstudio?      @relation("PlanEstudio")
  obiterComuniquese   ObiterComuniquese[]

  // El Diario — Análisis y Ensayos
  analisisCreados         AnalisisSentencia[]   @relation("AnalisisCreados")
  analisisApoyos          AnalisisApoyo[]       @relation("AnalisisApoyos")
  analisisGuardados       AnalisisGuardado[]    @relation("AnalisisGuardados")
  analisisComuniquese     AnalisisComuniquese[] @relation("AnalisisComuniquese")
  ensayosCreados          Ensayo[]              @relation("EnsayosCreados")
  ensayoApoyos            EnsayoApoyo[]         @relation("EnsayoApoyos")
  ensayoGuardados         EnsayoGuardado[]      @relation("EnsayoGuardados")
  ensayoComuniquese       EnsayoComuniquese[]   @relation("EnsayoComuniquese")

  // Definiciones
  definicionIntentos      DefinicionIntento[]   @relation("DefinicionIntentos")

  // Completar Espacios
  fillBlankAttempts       FillBlankAttempt[]     @relation("FillBlankAttempts")

  // Identificar Errores
  errorIdAttempts         ErrorIdentificationAttempt[] @relation("ErrorIdAttempts")

  // Ordenar Secuencias
  orderSequenceAttempts   OrderSequenceAttempt[] @relation("OrderSequenceAttempts")

  // Relacionar Columnas
  matchColumnsAttempts    MatchColumnsAttempt[]  @relation("MatchColumnsAttempts")

  // Casos Prácticos
  casoPracticoAttempts   CasoPracticoAttempt[] @relation("CasoPracticoAttempts")

  // Dictado Jurídico
  dictadoAttempts        DictadoAttempt[]      @relation("DictadoAttempts")

  // Líneas de Tiempo
  timelineAttempts       TimelineAttempt[]     @relation("TimelineAttempts")

  // Expediente Abierto
  expedienteArgumentos   ExpedienteArgumento[] @relation("ExpedienteArgumentos")
  expedienteVotos        ExpedienteVoto[]      @relation("ExpedienteVotos")
  expedienteComentarios  ExpedienteComentario[] @relation("ExpedienteComentarios")

  // Debates Jurídicos
  debatesComoAutor1      DebateJuridico[]      @relation("DebateAutor1")
  debatesComoAutor2      DebateJuridico[]      @relation("DebateAutor2")
  debateVotos            DebateVoto[]          @relation("DebateVotos")

  // Colaboración
  colaboracionInvitaciones ColaboracionInvitacion[] @relation("ColaboracionInvitado")

  // Peer Review
  reviewsRealizados      PeerReview[]          @relation("ReviewsRealizados")

  // XP Log (desglose por categoría)
  xpLogs                  XpLog[]               @relation("XpLogs")
}

model Flashcard {
  id          String  @id @default(cuid())
  front       String
  back        String
  rama        Rama
  codigo      Codigo
  libro       Libro
  titulo      String
  parrafo     String?
  leyAnexa    String?
  articuloRef String?
  dificultad  String  @default("BASICO")

  progress  UserFlashcardProgress[]
  favorites FlashcardFavorite[]

  @@index([rama, libro])
}

model UserFlashcardProgress {
  id             String    @id @default(cuid())
  userId         String
  flashcardId    String
  easeFactor     Float     @default(2.5)
  interval       Int       @default(0)
  repetitions    Int       @default(0)
  nextReviewAt   DateTime  @default(now())
  lastReviewedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
}

model MCQ {
  id            String  @id @default(cuid())
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String
  explanation   String?
  rama          Rama
  codigo        Codigo
  libro         Libro
  titulo        String
  parrafo       String?
  leyAnexa      String?
  articuloRef   String?
  dificultad    String  @default("BASICO")

  attempts           UserMCQAttempt[]
  causaAnswers       CausaAnswer[]
  causaRoomQuestions CausaRoomQuestion[]
  causaRoomAnswers   CausaRoomAnswer[]

  @@index([rama, libro])
}

model UserMCQAttempt {
  id             String   @id @default(cuid())
  userId         String
  mcqId          String
  selectedOption String
  isCorrect      Boolean
  attemptedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcq  MCQ  @relation(fields: [mcqId], references: [id], onDelete: Cascade)
}

model TrueFalse {
  id          String  @id @default(cuid())
  statement   String
  isTrue      Boolean
  explanation String?
  rama        Rama
  codigo      Codigo
  libro       Libro
  titulo      String
  parrafo     String?
  leyAnexa    String?
  articuloRef String?
  dificultad  String  @default("BASICO")

  attempts UserTrueFalseAttempt[]

  @@index([rama, libro])
}

model UserTrueFalseAttempt {
  id             String   @id @default(cuid())
  userId         String
  trueFalseId    String
  selectedAnswer Boolean
  isCorrect      Boolean
  attemptedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trueFalse TrueFalse @relation(fields: [trueFalseId], references: [id], onDelete: Cascade)
}

model ContentReport {
  id          String   @id @default(cuid())
  userId      String
  contentType String
  contentId   String
  reason      String
  description String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CurriculumProgress {
  id              String    @id @default(cuid())
  userId          String
  rama            Rama
  libro           Libro
  titulo          String
  completions     Int       @default(0)
  lastCompletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, rama, libro, titulo])
}

// ─── Ligas Semanales ─────────────────────────────────────

model League {
  id        String     @id @default(cuid())
  tier      LeagueTier
  gradoRef  Int        @default(1)
  weekStart DateTime
  weekEnd   DateTime
  createdAt DateTime   @default(now())

  members LeagueMember[]

  @@index([tier, weekStart])
  @@index([gradoRef, weekStart])
}

model LeagueMember {
  id       String @id @default(cuid())
  userId   String
  leagueId String
  weeklyXp Int    @default(0)
  rank     Int?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
  @@index([leagueId, weeklyXp])
}

// ─── Causas (Duelos 1v1) ────────────────────────────────

model Causa {
  id           String      @id @default(cuid())
  challengerId String
  challengedId String
  status       CausaStatus @default(PENDING)
  winnerId     String?
  createdAt    DateTime    @default(now())
  startedAt    DateTime?
  completedAt  DateTime?

  challenger User  @relation("CausasRetadas", fields: [challengerId], references: [id], onDelete: Cascade)
  challenged User  @relation("CausasRecibidas", fields: [challengedId], references: [id], onDelete: Cascade)
  winner     User? @relation("CausasGanadas", fields: [winnerId], references: [id], onDelete: SetNull)

  answers CausaAnswer[]

  @@index([challengerId, status])
  @@index([challengedId, status])
}

model CausaAnswer {
  id             String   @id @default(cuid())
  causaId        String
  userId         String
  mcqId          String
  questionIdx    Int
  selectedOption String?
  isCorrect      Boolean?
  timeMs         Int?
  score          Int      @default(0)
  answeredAt     DateTime @default(now())

  causa Causa @relation(fields: [causaId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcq   MCQ   @relation(fields: [mcqId], references: [id], onDelete: Cascade)

  @@unique([causaId, userId, questionIdx])
}

// ─── Insignias ───────────────────────────────────────────

model UserBadge {
  id       String    @id @default(cuid())
  userId   String
  badge    BadgeSlug
  earnedAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badge])
}

// ─── CausaRoom (Causa Grupal / Multiplayer) ──────────────

model CausaRoom {
  id               String   @id @default(cuid())
  mode             String   @default("individual")
  status           String   @default("lobby")
  maxPlayers       Int      @default(10)
  createdById      String
  rama             String?
  difficulty       String?
  timeLimitSeconds Int      @default(30)
  createdAt        DateTime @default(now())

  createdBy    User                @relation("CausaRoomsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  participants CausaParticipant[]
  questions    CausaRoomQuestion[]
  answers      CausaRoomAnswer[]

  @@index([status])
}

model CausaParticipant {
  roomId   String
  userId   String
  score    Int      @default(0)
  position Int?
  joinedAt DateTime @default(now())

  room CausaRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
}

model CausaRoomQuestion {
  id            String @id @default(cuid())
  roomId        String
  mcqId         String
  questionIndex Int

  room CausaRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  mcq  MCQ       @relation(fields: [mcqId], references: [id], onDelete: Cascade)

  @@unique([roomId, questionIndex])
}

model CausaRoomAnswer {
  id             String   @id @default(cuid())
  roomId         String
  userId         String
  mcqId          String
  questionIndex  Int
  selectedOption String?
  isCorrect      Boolean?
  timeMs         Int?
  score          Int      @default(0)
  answeredAt     DateTime @default(now())

  room CausaRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcq  MCQ       @relation(fields: [mcqId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId, questionIndex])
}

// ─── Flashcard Favoritos ─────────────────────────────────

model FlashcardFavorite {
  id          String   @id @default(cuid())
  userId      String
  flashcardId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
}

// ─── La Sala ─────────────────────────────────────────────

model Ayudantia {
  id             String          @id @default(cuid())
  userId         String
  type           AyudantiaType
  materia        String
  titulo         String          @default("")
  format         AyudantiaFormat
  priceType      PriceType
  priceAmount    Int?
  description    String
  universidad    String
  orientadaA     String[]
  contactMethod  ContactMethod
  contactValue   String
  disponibilidad String?
  isActive       Boolean         @default(true)
  isHidden       Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  reportCount    Int             @default(0)

  user         User              @relation("AyudantiasCreadas", fields: [userId], references: [id], onDelete: Cascade)
  reports      AyudantiaReport[]
  sesiones     AyudantiaSesion[]
  salaReportes SalaReporte[]

  @@index([type, isActive, isHidden])
  @@index([userId])
  @@index([materia])
}

model AyudantiaReport {
  id           String   @id @default(cuid())
  ayudantiaId  String
  reportedById String
  reason       String
  createdAt    DateTime @default(now())

  ayudantia  Ayudantia @relation(fields: [ayudantiaId], references: [id], onDelete: Cascade)
  reportedBy User      @relation(fields: [reportedById], references: [id])

  @@unique([ayudantiaId, reportedById])
}

model AyudantiaStreak {
  userId          String @id
  monthsActive    Int    @default(0)
  lastActiveMonth String
  longestStreak   Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AyudantiaSesion {
  id            String    @id @default(uuid())
  ayudantiaId   String
  ayudantia     Ayudantia @relation(fields: [ayudantiaId], references: [id], onDelete: Cascade)

  tutorId       String
  tutor         User      @relation("SesionesTutor", fields: [tutorId], references: [id])
  estudianteId  String
  estudiante    User      @relation("SesionesEstudiante", fields: [estudianteId], references: [id])

  fecha         DateTime
  duracionMin   Int?
  materia       String
  notas         String?

  status        String    @default("pendiente") // "pendiente" | "confirmada" | "completada" | "cancelada"
  completadaAt  DateTime?
  canceladaAt   DateTime?
  canceladaPor  String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  evaluaciones  AyudantiaEvaluacion[]

  @@index([tutorId])
  @@index([estudianteId])
  @@index([ayudantiaId])
  @@index([status])
}

model AyudantiaEvaluacion {
  id            String          @id @default(uuid())
  sesionId      String
  sesion        AyudantiaSesion @relation(fields: [sesionId], references: [id], onDelete: Cascade)

  evaluadorId   String
  evaluador     User            @relation("EvaluacionesDadas", fields: [evaluadorId], references: [id])
  evaluadoId    String
  evaluado      User            @relation("EvaluacionesRecibidas", fields: [evaluadoId], references: [id])

  rating        Int             // 1-5
  comentario    String?

  createdAt     DateTime        @default(now())

  @@unique([sesionId, evaluadorId])
  @@index([evaluadoId])
}

// ─── Pasantías ──────────────────────────────────────────

model Pasantia {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation("PasantiasCreadas", fields: [userId], references: [id])

  empresa             String
  areaPractica        String
  titulo              String
  descripcion         String
  ciudad              String
  formato             String   // "presencial" | "remoto" | "hibrido"
  duracion            String?
  remuneracion        String   // "pagada" | "no_pagada" | "a_convenir"
  montoRemu           String?
  requisitos          String?
  metodoPostulacion   String   // "email" | "formulario" | "en_plataforma"
  contactoPostulacion String?

  isActive            Boolean  @default(true)
  isHidden            Boolean  @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  salaReportes        SalaReporte[]

  @@index([userId])
  @@index([areaPractica])
  @@index([isActive, isHidden, createdAt(sort: Desc)])
}

// ─── Eventos Académicos ─────────────────────────────────

model EventoAcademico {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation("EventosCreados", fields: [userId], references: [id])

  titulo          String
  descripcion     String
  organizador     String
  fecha           DateTime
  fechaFin        DateTime?
  hora            String?
  formato         String    // "presencial" | "online" | "hibrido"
  lugar           String?
  linkOnline      String?
  costo           String    // "gratis" | "pagado"
  montoCosto      String?
  linkInscripcion String?
  materias        String?

  approvalStatus  String    @default("pendiente") // "pendiente" | "aprobado" | "rechazado"
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?

  isActive        Boolean   @default(true)
  isHidden        Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  interesados     EventoInteres[]
  salaReportes    SalaReporte[]

  @@index([userId])
  @@index([approvalStatus])
  @@index([isActive, isHidden, fecha(sort: Asc)])
}

model EventoInteres {
  id        String          @id @default(uuid())
  eventoId  String
  evento    EventoAcademico @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation("EventosInteres", fields: [userId], references: [id])

  createdAt DateTime        @default(now())

  @@unique([eventoId, userId])
  @@index([userId])
}

// ─── Ofertas de Trabajo ─────────────────────────────────

model OfertaTrabajo {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation("OfertasCreadas", fields: [userId], references: [id])

  empresa             String
  cargo               String
  areaPractica        String
  descripcion         String
  ciudad              String
  formato             String   // "presencial" | "remoto" | "hibrido"
  tipoContrato        String   // "indefinido" | "plazo_fijo" | "honorarios" | "part_time"
  experienciaReq      String?
  remuneracion        String?
  requisitos          String?
  metodoPostulacion   String
  contactoPostulacion String?

  isActive            Boolean  @default(true)
  isHidden            Boolean  @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  salaReportes        SalaReporte[]

  @@index([userId])
  @@index([areaPractica])
  @@index([isActive, isHidden, createdAt(sort: Desc)])
}

// ─── Reportes de La Sala (unificado) ────────────────────

model SalaReporte {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation("ReportesCreados", fields: [userId], references: [id])

  ayudantiaId   String?
  ayudantia     Ayudantia?       @relation(fields: [ayudantiaId], references: [id], onDelete: Cascade)
  pasantiaId    String?
  pasantia      Pasantia?        @relation(fields: [pasantiaId], references: [id], onDelete: Cascade)
  eventoId      String?
  evento        EventoAcademico? @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  ofertaId      String?
  oferta        OfertaTrabajo?   @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
  analisisId    String?
  analisis      AnalisisSentencia? @relation(fields: [analisisId], references: [id], onDelete: Cascade)
  ensayoId      String?
  ensayo        Ensayo?          @relation(fields: [ensayoId], references: [id], onDelete: Cascade)

  motivo        String   // "spam" | "informacion_falsa" | "contenido_inapropiado" | "oferta_sospechosa" | "otro"
  descripcion   String?

  reviewStatus  String   @default("pendiente") // "pendiente" | "accion_tomada" | "descartado"
  reviewedAt    DateTime?
  reviewedBy    String?

  createdAt     DateTime @default(now())

  @@index([ayudantiaId])
  @@index([pasantiaId])
  @@index([eventoId])
  @@index([ofertaId])
  @@index([analisisId])
  @@index([ensayoId])
  @@index([reviewStatus])
}

// ─── Notificaciones ─────────────────────────────────────

model Notification {
  id            String           @id @default(cuid())
  type          NotificationType
  title         String
  body          String
  senderId      String?
  targetUserId  String?
  targetSegment String?
  metadata      Json?
  sentViaEmail  Boolean          @default(false)
  createdAt     DateTime         @default(now())

  userNotifications UserNotification[]
}

model UserNotification {
  id             String    @id @default(cuid())
  userId         String
  notificationId String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ─── Colegas (Amigos) ────────────────────────────────────

model ColegaRequest {
  id         String       @id @default(cuid())
  senderId   String
  receiverId String
  status     ColegaStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  sender   User @relation("ColegasSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ColegasReceived", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
}

// ─── Calendario Personal ──────────────────────────────────

model CalendarEvent {
  id              String   @id @default(cuid())
  userId          String
  title           String
  description     String?
  eventType       String   @default("personal")
  startDate       DateTime
  endDate         DateTime?
  allDay          Boolean  @default(false)
  color           String?
  sourceEventoId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceEventoId])
  @@index([userId, startDate])
}

// ─── Countdowns Personales ───────────────────────────────

model UserCountdown {
  id      String   @id @default(cuid())
  userId  String
  titulo  String
  fecha   DateTime
  color   String
  isGrado Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("UserCountdowns", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Solicitudes de CV ─────────────────────────────────

model CvRequest {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  message    String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  fromUser User @relation("CvRequestsSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("CvRequestsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
}

// ─── Admin Logs ─────────────────────────────────────────

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([action, createdAt])
}

// ─── Suscripciones ──────────────────────────────────────

model Subscription {
  id             String             @id @default(cuid())
  userId         String
  plan           Plan
  amount         Int
  currency       String             @default("CLP")
  status         SubscriptionStatus @default(PENDING)
  transbankToken String?
  createdAt      DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── El Diario (Publicacion Academica) ─────────────────

model DiarioPost {
  id            String              @id @default(cuid())
  userId        String
  formato       DiarioFormato
  visibilidad   DiarioVisibilidad   @default(PUBLICO)
  titulo        String
  materia       String?
  // Obiter Dictum
  contenido     String?
  // Analisis de Fallos
  rol           String?
  tribunal      String?
  fecha         String?
  partes        String?
  hechos        String?
  ratio         String?
  norma         String?
  opinion       String?
  pdfUrl        String?
  // Metricas
  views         Int                 @default(0)
  // Citas (self-relation)
  citadoDeId    String?
  citadoDe      DiarioPost?         @relation("Citas", fields: [citadoDeId], references: [id], onDelete: SetNull)
  citas         DiarioPost[]        @relation("Citas")
  // Relations
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashtags      DiarioPostHashtag[]
  guardados     DiarioGuardado[]
  heroSlides    HeroSlide[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId, createdAt])
  @@index([formato, createdAt])
}

model DiarioHashtag {
  id             String              @id @default(cuid())
  tag            String              @unique
  count          Int                 @default(0)
  isContingencia Boolean             @default(false)
  pinned         Boolean             @default(false)
  hidden         Boolean             @default(false)
  posts          DiarioPostHashtag[]
  createdAt      DateTime            @default(now())
}

model DiarioPostHashtag {
  postId    String
  hashtagId String
  post      DiarioPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag   DiarioHashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
}

model DiarioGuardado {
  id        String     @id @default(cuid())
  userId    String
  postId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      DiarioPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([userId, postId])
}

// ─── Simulacro de Interrogación Oral ─────────────────────

model SimulacroSesion {
  id              String            @id @default(cuid())
  userId          String
  interrogadorId  InterrogadorId
  fuente          FuenteSimulacro
  rama            String?
  libro           String?
  titulo          String?
  apuntesNombre   String?
  apuntesTexto    String?
  totalPreguntas  Int               @default(10)
  preguntaActual  Int               @default(0)
  correctas       Int               @default(0)
  incorrectas     Int               @default(0)
  nivelActual     NivelDificultad   @default(BASICO)
  completada      Boolean           @default(false)
  opinionFinal    String?           // Opinión del interrogador al finalizar
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  preguntas       SimulacroPregunta[]
  reportes        SimulacroReporte[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId, createdAt])
}

model SimulacroReporte {
  id          String          @id @default(cuid())
  sesionId    String
  userId      String
  tipo        String          // sistema | contenido | otro
  descripcion String?
  sesion      SimulacroSesion @relation(fields: [sesionId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())

  @@index([createdAt])
}

model SimulacroPregunta {
  id                  String            @id @default(cuid())
  sesionId            String
  numero              Int
  nivel               NivelDificultad
  preguntaTexto       String
  respuestaUser       String?
  evaluacion          String?
  correcta            Boolean?
  intercambioTexto    String?           // Texto del intercambio (aclaración o repregunta)
  respuestaIntercambio String?          // Segunda respuesta del usuario
  tipoIntercambio     String?           // "aclaracion" | "repregunta" | null
  sesion              SimulacroSesion   @relation(fields: [sesionId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
}

// ─── Hero Carrusel & Anunciantes ─────────────────────────

model HeroSlide {
  id              String        @id @default(uuid())
  origen          SlideOrigen   @default(editorial)
  tipo            String
  imagenUrl       String
  imagenPosicion  String        @default("center")
  overlayOpacidad Float         @default(0.45)
  titulo          String
  subtitulo       String?
  ctaTexto        String        @default("Ver más")
  ctaUrl          String
  ctaExterno      Boolean       @default(false)
  diarioPostId    String?
  diarioPost      DiarioPost?   @relation(fields: [diarioPostId], references: [id], onDelete: SetNull)
  anuncianteId    String?
  anunciante      Anunciante?   @relation(fields: [anuncianteId], references: [id], onDelete: SetNull)
  precioPactado   Int?
  tipoCobro       String?
  ubicaciones     String[]      @default(["dashboard"])
  estado          SlideEstado   @default(borrador)
  fechaInicio     DateTime      @default(now())
  fechaFin        DateTime?
  orden           Int           @default(0)
  impresiones     Int           @default(0)
  clics           Int           @default(0)
  eventos         HeroSlideEvento[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model HeroSlideEvento {
  id        String    @id @default(uuid())
  slideId   String
  slide     HeroSlide @relation(fields: [slideId], references: [id], onDelete: Cascade)
  tipo      String
  ubicacion String
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
}

model Anunciante {
  id               String      @id @default(uuid())
  nombre           String
  tipo             String
  contactoNombre   String?
  contactoEmail    String
  contactoTelefono String?
  rut              String?
  activo           Boolean     @default(true)
  slides           HeroSlide[]
  createdAt        DateTime    @default(now())
}

// ─── Plan Institucional ──────────────────────────────────

model RegistroInteres {
  id                String           @id @default(cuid())
  nombreInstitucion String
  tipoInstitucion   TipoInstitucion
  nombreContacto    String
  emailContacto     String
  telefono          String?
  mensaje           String?
  createdAt         DateTime         @default(now())

  @@index([createdAt])
  @@index([tipoInstitucion])
}

// ─── Obiter Dictum (Microblogging Jurídico) ──────────────

model ObiterDictum {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  content          String   // Texto del obiter, máx ~1000 caracteres (~200 palabras)

  // Metadata opcionales
  materia          String?  // "acto_juridico", "obligaciones", "procesal", etc.
  tipo             String?  // "reflexion", "pregunta", "cita_doctrinal", "opinion", "dato"

  // === HILOS ===
  threadId         String?
  threadOrder      Int?     // 1 a 10 (máximo 10 partes por hilo)

  // === CITAS ===
  citedObiterId    String?
  citedObiter      ObiterDictum?    @relation("CitaObiter", fields: [citedObiterId], references: [id], onDelete: SetNull)
  citadoPor        ObiterDictum[]   @relation("CitaObiter")

  citedAnalisisId  String?
  citedAnalisis    AnalisisSentencia? @relation("CitaAnalisis", fields: [citedAnalisisId], references: [id], onDelete: SetNull)
  citedEnsayoId    String?
  citedEnsayo      Ensayo?          @relation("CitaEnsayo", fields: [citedEnsayoId], references: [id], onDelete: SetNull)

  // === CONTADORES DESNORMALIZADOS ===
  apoyosCount      Int @default(0)
  citasCount       Int @default(0)
  guardadosCount   Int @default(0)
  comuniqueseCount Int @default(0)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relaciones
  apoyos           ObiterApoyo[]
  guardados        ObiterGuardado[]
  comuniquese      ObiterComuniquese[]

  @@index([userId])
  @@index([threadId, threadOrder])
  @@index([citedObiterId])
  @@index([createdAt(sort: Desc)])
  @@index([materia])
}

model ObiterApoyo {
  id        String       @id @default(cuid())
  obiterId  String
  obiter    ObiterDictum @relation(fields: [obiterId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([obiterId, userId])
  @@index([userId])
}

model ObiterGuardado {
  id        String       @id @default(cuid())
  obiterId  String
  obiter    ObiterDictum @relation(fields: [obiterId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([obiterId, userId])
  @@index([userId])
}

model ObiterComuniquese {
  id        String       @id @default(cuid())
  obiterId  String
  obiter    ObiterDictum @relation(fields: [obiterId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([obiterId, userId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

// ─── El Diario — Análisis de Sentencia ───────────────────

model AnalisisSentencia {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation("AnalisisCreados", fields: [userId], references: [id])

  // === FICHA TÉCNICA DEL FALLO ===
  tribunal        String
  numeroRol       String
  fechaFallo      DateTime
  partes          String
  materia         String
  falloUrl        String?
  falloPdfUrl     String?

  // === 4 SECCIONES DE CONTENIDO ===
  hechos          String
  ratioDecidendi  String
  opinion         String

  // === METADATA PARA FEED Y BÚSQUEDA ===
  titulo          String
  resumen         String
  tags            String?
  tiempoLectura   Int     @default(5)

  // === FORMATO ===
  formato         String  @default("completo") // "mini" | "completo"

  // === FALLO DE LA SEMANA (opcional) ===
  falloDeLaSemanaId String?
  falloDeLaSemana   FalloDeLaSemana? @relation(fields: [falloDeLaSemanaId], references: [id])

  // === COLABORACIÓN ===
  colaborativo    Boolean  @default(false)
  coAutores       String?  // JSON array of userIds
  estadoBorrador  String   @default("publicado") // "borrador" | "invitando" | "editando" | "publicado"

  // === PEER REVIEW ===
  estadoReview    String?  // null | "solicitado" | "en_revision" | "revisado"

  // === VISIBILIDAD ===
  showInFeed      Boolean @default(true)
  isActive        Boolean @default(true)
  isHidden        Boolean @default(false)

  // === CONTADORES DESNORMALIZADOS ===
  apoyosCount      Int @default(0)
  citasCount       Int @default(0)
  guardadosCount   Int @default(0)
  comuniqueseCount Int @default(0)
  viewsCount       Int @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  apoyos          AnalisisApoyo[]
  guardados       AnalisisGuardado[]
  comuniquese     AnalisisComuniquese[]
  reportes        SalaReporte[]
  citadoPorObiters ObiterDictum[] @relation("CitaAnalisis")

  @@index([userId])
  @@index([materia])
  @@index([isActive, isHidden, createdAt(sort: Desc)])
}

model AnalisisApoyo {
  id          String            @id @default(uuid())
  analisisId  String
  analisis    AnalisisSentencia @relation(fields: [analisisId], references: [id], onDelete: Cascade)
  userId      String
  user        User              @relation("AnalisisApoyos", fields: [userId], references: [id])
  createdAt   DateTime          @default(now())

  @@unique([analisisId, userId])
  @@index([userId])
}

model AnalisisGuardado {
  id          String            @id @default(uuid())
  analisisId  String
  analisis    AnalisisSentencia @relation(fields: [analisisId], references: [id], onDelete: Cascade)
  userId      String
  user        User              @relation("AnalisisGuardados", fields: [userId], references: [id])
  createdAt   DateTime          @default(now())

  @@unique([analisisId, userId])
  @@index([userId])
}

model AnalisisComuniquese {
  id          String            @id @default(uuid())
  analisisId  String
  analisis    AnalisisSentencia @relation(fields: [analisisId], references: [id], onDelete: Cascade)
  userId      String
  user        User              @relation("AnalisisComuniquese", fields: [userId], references: [id])
  createdAt   DateTime          @default(now())

  @@unique([analisisId, userId])
  @@index([userId])
}

// ─── El Diario — Ensayos ─────────────────────────────────

model Ensayo {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation("EnsayosCreados", fields: [userId], references: [id])

  // === METADATA ===
  titulo          String
  materia         String
  tipo            String   // "opinion" | "nota_doctrinaria" | "comentario_reforma" | "analisis_comparado" | "tesis" | "otro"
  tags            String?
  resumen         String?

  // === ARCHIVO ===
  archivoUrl      String
  archivoNombre   String
  archivoFormato  String   // "pdf" | "docx"
  archivoTamano   Int

  // === COLABORACIÓN ===
  colaborativo    Boolean  @default(false)
  coAutores       String?  // JSON array of userIds
  estadoBorrador  String   @default("publicado")

  // === PEER REVIEW ===
  estadoReview    String?

  // === VISIBILIDAD ===
  showInFeed      Boolean @default(true)
  isActive        Boolean @default(true)
  isHidden        Boolean @default(false)

  // === CONTADORES DESNORMALIZADOS ===
  apoyosCount      Int @default(0)
  citasCount       Int @default(0)
  guardadosCount   Int @default(0)
  comuniqueseCount Int @default(0)
  viewsCount       Int @default(0)
  downloadsCount   Int @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  apoyos          EnsayoApoyo[]
  guardados       EnsayoGuardado[]
  comuniquese     EnsayoComuniquese[]
  reportes        SalaReporte[]
  citadoPorObiters ObiterDictum[] @relation("CitaEnsayo")

  @@index([userId])
  @@index([materia])
  @@index([tipo])
  @@index([isActive, isHidden, createdAt(sort: Desc)])
}

model EnsayoApoyo {
