// Iuris Studio — Schema de base de datos
// Plataforma de aprendizaje de Derecho Civil y Procesal Civil (Chile)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

