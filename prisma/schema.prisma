  user      User     @relation("EnsayoApoyos", fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([ensayoId, userId])
  @@index([userId])
}

model EnsayoGuardado {
  id        String   @id @default(uuid())
  ensayoId  String
  ensayo    Ensayo   @relation(fields: [ensayoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("EnsayoGuardados", fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([ensayoId, userId])
  @@index([userId])
}

model EnsayoComuniquese {
  id        String   @id @default(uuid())
  ensayoId  String
  ensayo    Ensayo   @relation(fields: [ensayoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("EnsayoComuniquese", fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([ensayoId, userId])
  @@index([userId])
}

// ─── Mi Examen (Plan de Estudio Personalizado) ───────────

model ExamenConfig {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Datos del examen
  universidad     String
  sede            String?
  fechaExamen     DateTime?

  // Cedulario original
  cedularioTexto  String?
  cedularioUrl    String?
  cedularioSource String?   // "text" | "pdf"

  // Estado del parsing
  parseStatus     String    @default("pending") // "pending" | "parsing" | "completed" | "error"
  parseError      String?
  parsedAt        DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  temas           ExamenTema[]

  @@index([userId])
}

model ExamenTema {
  id                String       @id @default(uuid())
  examenConfigId    String
  examenConfig      ExamenConfig @relation(fields: [examenConfigId], references: [id], onDelete: Cascade)

  // Datos del tema extraído del cedulario
  nombre            String
  descripcion       String?
  categoriaOriginal String?

  // Mapeo al contenido de Studio Iuris
  materiaMapping    String?   // Valor de rama que corresponde: "DERECHO_CIVIL", "DERECHO_PROCESAL_CIVIL"
  libroMapping      String?   // Valor de libro si hay match más granular
  tituloMapping     String?   // Valor de titulo si hay match aún más específico

  // Disponibilidad de contenido
  flashcardsDisponibles Int     @default(0)
  mcqDisponibles        Int     @default(0)
  vfDisponibles         Int     @default(0)
  tieneContenido        Boolean @default(false)

  // Progreso del usuario (se actualiza periódicamente)
  flashcardsDominadas   Int     @default(0)
  mcqCorrectas          Int     @default(0)
  vfCorrectas           Int     @default(0)
  porcentajeAvance      Float   @default(0) // 0-100

  // Orden y peso
  orden                 Int     @default(0)
  peso                  Float   @default(1.0)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([examenConfigId])
  @@index([materiaMapping])
}

model ExamenReporte {
  id                  String    @id @default(uuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  universidad         String
  fechaExamen         DateTime
  aprobado            Boolean?

  materiasPreguntadas String    // JSON: ["obligaciones", "procesal_civil", ...]

  comentario          String?
  dificultadPercibida Int?      // 1-5

  createdAt           DateTime  @default(now())

  @@index([universidad])
  @@index([createdAt(sort: Desc)])
}

// ─── Definiciones ─────────────────────────────────────────

model Definicion {
  id            String   @id @default(cuid())

  concepto      String
  definicion    String
  rama          Rama
  libro         String?
  titulo        String?

  distractor1   String
  distractor2   String
  distractor3   String

  explicacion   String?
  articuloRef   String?

  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  intentos      DefinicionIntento[]

  @@index([rama])
  @@index([isActive, rama])
}

model DefinicionIntento {
  id            String   @id @default(cuid())
  definicionId  String
  definicion    Definicion @relation(fields: [definicionId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation("DefinicionIntentos", fields: [userId], references: [id], onDelete: Cascade)

  respuesta     String
  correcta      Boolean
  tiempoMs      Int?

  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([definicionId])
  @@index([userId, createdAt(sort: Desc)])
}

// ─── XP Log — Desglose por categoría ────────────────────────

model XpLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("XpLogs", fields: [userId], references: [id], onDelete: Cascade)
  amount    Int      // Puede ser negativo (penalización)
  category  String   // "estudio" | "simulacro" | "causas" | "publicaciones" | "bonus"
  detalle   String?  // "MCQ", "Flashcards", "V/F", "Definiciones", "Simulacro Oral", etc.
  materia   String?  // "Derecho Civil", "Procesal Civil", etc. (si aplica)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, category])
  @@index([userId, createdAt(sort: Desc)])
}

// ═══ SPONSORS ════════════════════════════════════════════════════

model SponsorBanner {
  id          String    @id @default(uuid())
  nombre      String                         // Nombre del sponsor (interno)
  titulo      String?                        // Texto principal del banner
  descripcion String?                        // Texto secundario
  imagenUrl   String?                        // URL de la imagen del banner
  linkUrl     String?                        // URL destino al hacer click
  posicion    String    @default("lateral")  // "principal" | "lateral" | "footer"
  activo      Boolean   @default(true)
  fechaInicio DateTime  @default(now())
  fechaFin    DateTime?                      // null = indefinido
  clicks      Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([activo, posicion])
  @@index([fechaInicio, fechaFin])
}

// ─── Plan de Estudios ──────────────────────────────────────

model PlanEstudio {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation("PlanEstudio", fields: [userId], references: [id])

  // PDFs subidos (hasta 3)
  pdf1Url         String?
  pdf1Nombre      String?
  pdf1Texto       String?
  pdf2Url         String?
  pdf2Nombre      String?
  pdf2Texto       String?
  pdf3Url         String?
  pdf3Nombre      String?
  pdf3Texto       String?

  // Configuración
  fechaExamen     DateTime
  horasEstudioDia Int      @default(3)
  diasDescanso    String   @default("[]")       // JSON: ["domingo"]
  modoGeneracion  String   @default("automatico") // "automatico" | "manual"

  // Estado
  estado          String   @default("configurando") // configurando | generando | activo | completado

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  temas           PlanTema[]
  sesiones        PlanSesionDiaria[]
}

model PlanTema {
  id              String      @id @default(uuid())
  planId          String
  plan            PlanEstudio @relation(fields: [planId], references: [id], onDelete: Cascade)

  // Vinculación al Índice Maestro
  rama            String      // "DERECHO_CIVIL" | "DERECHO_PROCESAL_CIVIL" | "DERECHO_ORGANICO"
  libro           String?
  titulo          String
  parrafo         String?

  // Metadata
  nombre          String
  prioridad       Int         @default(2) // 1=alta, 2=media, 3=baja
  estimacionHoras Float       @default(1)

  // Progreso
  completado      Boolean     @default(false)
  porcentaje      Float       @default(0) // 0-100

  createdAt       DateTime    @default(now())

  @@index([planId])
  @@index([planId, rama])
}

model PlanSesionDiaria {
  id              String      @id @default(uuid())
  planId          String
  plan            PlanEstudio @relation(fields: [planId], references: [id], onDelete: Cascade)

  fecha           DateTime
  actividades     String      @default("[]") // JSON: [{ temaId, temaNombre, actividad, duracionMin }]

  completada      Boolean     @default(false)
  xpGanado        Int         @default(0)

  calendarEventId String?

  createdAt       DateTime    @default(now())

  @@index([planId, fecha])
  @@unique([planId, fecha])
}

// ─── Completar Espacios en Blanco ─────────────────────────

model FillBlank {
  id              String   @id @default(cuid())

  textoConBlancos String   // "El artículo {1} del CC establece que {2}..."
  blancos         String   // JSON: [{ id: 1, correcta: "...", opciones: [...] }]
  explicacion     String?

  rama            String
  libro           String?
  titulo          String?
  materia         String?
  dificultad      Int      @default(2)

  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())

  attempts        FillBlankAttempt[]

  @@index([rama, activo])
}

model FillBlankAttempt {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation("FillBlankAttempts", fields: [userId], references: [id], onDelete: Cascade)
  fillBlankId    String
  fillBlank      FillBlank @relation(fields: [fillBlankId], references: [id], onDelete: Cascade)

  respuestas     String    // JSON: [{ blancoId: 1, respuesta: "...", correcta: true }]
  todosCorrectos Boolean

  createdAt      DateTime  @default(now())

  @@index([userId, createdAt])
}

// ─── Identificar Errores ──────────────────────────────────

model ErrorIdentification {
  id                String   @id @default(cuid())

  textoConErrores   String
  segmentos         String   // JSON: [{ id: 0, texto: "...", esError: false }, { id: 1, texto: "condición resolutoria", esError: true, textoCorrecto: "...", explicacion: "..." }]
  totalErrores      Int
  explicacionGeneral String?

  rama              String
  libro             String?
  titulo            String?
  materia           String?
  dificultad        Int      @default(2)

  activo            Boolean  @default(true)
  createdAt         DateTime @default(now())

  attempts          ErrorIdentificationAttempt[]

  @@index([rama, activo])
}

model ErrorIdentificationAttempt {
  id                    String              @id @default(cuid())
  userId                String
  user                  User                @relation("ErrorIdAttempts", fields: [userId], references: [id], onDelete: Cascade)
  errorIdentificationId String
  errorIdentification   ErrorIdentification @relation(fields: [errorIdentificationId], references: [id], onDelete: Cascade)

  selecciones           String              // JSON: [{ segmentoId: 1, seleccionado: true }]
  aciertos              Int
  fallosPositivos       Int

  createdAt             DateTime            @default(now())

  @@index([userId, createdAt])
}

// ─── Ordenar Secuencias ───────────────────────────────────

model OrderSequence {
  id             String   @id @default(cuid())

  titulo         String
  instruccion    String?
  items          String   // JSON: [{ id: 1, texto: "...", orden: 1 }, ...]
  explicacion    String?

  rama           String
  libro          String?
  tituloMateria  String?
  materia        String?
  dificultad     Int      @default(2)

  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())

  attempts       OrderSequenceAttempt[]

  @@index([rama, activo])
}

model OrderSequenceAttempt {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation("OrderSequenceAttempts", fields: [userId], references: [id], onDelete: Cascade)
  orderSequenceId String
  orderSequence   OrderSequence @relation(fields: [orderSequenceId], references: [id], onDelete: Cascade)

  ordenUsuario    String        // JSON: [{ itemId: 1, posicion: 1 }, ...]
  correctos       Int
  totalItems      Int
  perfecto        Boolean

  createdAt       DateTime      @default(now())

  @@index([userId, createdAt])
}

// ─── Relacionar Columnas ──────────────────────────────────

model MatchColumns {
  id              String   @id @default(cuid())

  titulo          String
  instruccion     String?
  pares           String   // JSON: [{ id: 1, izquierda: "...", derecha: "..." }, ...]
  columnaIzqLabel String   @default("Concepto")
  columnaDerLabel String   @default("Definición")
  explicacion     String?

  rama            String
  libro           String?
  tituloMateria   String?
  materia         String?
  dificultad      Int      @default(2)

  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())

  attempts        MatchColumnsAttempt[]

  @@index([rama, activo])
}

model MatchColumnsAttempt {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation("MatchColumnsAttempts", fields: [userId], references: [id], onDelete: Cascade)
  matchColumnsId  String
  matchColumns    MatchColumns @relation(fields: [matchColumnsId], references: [id], onDelete: Cascade)

  conexiones      String       // JSON: [{ izquierdaId: 1, derechaId: 3 }, ...]
  correctas       Int
  totalPares      Int
  perfecto        Boolean

  createdAt       DateTime     @default(now())

  @@index([userId, createdAt])
}

// ─── Casos Prácticos ──────────────────────────────────────

model CasoPractico {
  id             String   @id @default(cuid())

  titulo         String
  hechos         String
  preguntas      String   // JSON: [{ id, tipo, pregunta, opciones, correcta, explicacion }]
  resumenFinal   String?

  rama           String
  libro          String?
  tituloMateria  String?
  materia        String?
  dificultad     Int      @default(2)

  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())

  attempts       CasoPracticoAttempt[]

  @@index([rama, activo])
}

model CasoPracticoAttempt {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation("CasoPracticoAttempts", fields: [userId], references: [id], onDelete: Cascade)
  casoPracticoId  String
  casoPractico    CasoPractico @relation(fields: [casoPracticoId], references: [id], onDelete: Cascade)

  respuestas      String       // JSON: [{ preguntaId, respuesta, correcta }]
  correctas       Int

  createdAt       DateTime     @default(now())

  @@index([userId, createdAt])
}

// ─── Dictado Jurídico ─────────────────────────────────────

model DictadoJuridico {
  id             String   @id @default(cuid())

  textoCompleto  String
  titulo         String

  rama           String
  libro          String?
  tituloMateria  String?
  materia        String?
  dificultad     Int      @default(2)

  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())

  attempts       DictadoAttempt[]

  @@index([rama, activo])
}

model DictadoAttempt {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation("DictadoAttempts", fields: [userId], references: [id], onDelete: Cascade)
  dictadoId         String
  dictado           DictadoJuridico @relation(fields: [dictadoId], references: [id], onDelete: Cascade)

  textoUsuario      String
  precision         Float
  palabrasCorrectas Int
  palabrasTotales   Int

  createdAt         DateTime        @default(now())

  @@index([userId, createdAt])
}

// ─── Líneas de Tiempo ─────────────────────────────────────

model Timeline {
  id             String   @id @default(cuid())

  titulo         String
  instruccion    String?
  eventos        String   // JSON: [{ id, texto, posicion, unidad, descripcion }]
  escala         String   @default("días")
  rangoMin       Int      @default(0)
  rangoMax       Int
  explicacion    String?

  rama           String
  libro          String?
  tituloMateria  String?
  materia        String?
  dificultad     Int      @default(2)

  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())

  attempts       TimelineAttempt[]

  @@index([rama, activo])
}

model TimelineAttempt {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("TimelineAttempts", fields: [userId], references: [id], onDelete: Cascade)
  timelineId     String
  timeline       Timeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  posiciones     String   // JSON: [{ eventoId, posicionUsuario }]
  correctos      Int
  totalEventos   Int
  perfecto       Boolean

  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

// ─── Expediente Abierto ───────────────────────────────────

model Expediente {
  id              String   @id @default(cuid())

  numero          Int      @unique
  titulo          String
  hechos          String
  pregunta        String

  rama            String
  materias        String?
  dificultad      Int      @default(2)

  bandoDemandante String   @default("Demandante")
  bandoDemandado  String   @default("Demandado")

  fechaApertura   DateTime @default(now())
  fechaCierre     DateTime
  estado          String   @default("abierto")

  cierreEditorial    String?
  mejorArgumentoId   String?

  creadoPor       String?
  propuestaPor    String?
  aprobado        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  argumentos      ExpedienteArgumento[]

  @@index([estado, fechaCierre])
  @@index([fechaApertura])
}

model ExpedienteArgumento {
  id              String     @id @default(cuid())
  expedienteId    String
  expediente      Expediente @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  userId          String
  user            User       @relation("ExpedienteArgumentos", fields: [userId], references: [id])

  bando           String
  posicion        String
  fundamentoNormativo String
  argumento       String

  jurisprudencia  String?
  normativa       String?

  votos           Int        @default(0)

  parentId        String?
  parent          ExpedienteArgumento?  @relation("ContraArgumentos", fields: [parentId], references: [id])
  contraArgumentos ExpedienteArgumento[] @relation("ContraArgumentos")

  votosRecibidos  ExpedienteVoto[]
  comentarios     ExpedienteComentario[]

  createdAt       DateTime   @default(now())

  @@index([expedienteId, votos])
  @@index([expedienteId, bando])
  @@index([userId])
}

model ExpedienteVoto {
  id           String              @id @default(cuid())
  argumentoId  String
  argumento    ExpedienteArgumento @relation(fields: [argumentoId], references: [id], onDelete: Cascade)
  userId       String
  user         User                @relation("ExpedienteVotos", fields: [userId], references: [id])

  createdAt    DateTime            @default(now())

  @@unique([argumentoId, userId])
}

model ExpedienteComentario {
  id           String              @id @default(cuid())
  argumentoId  String
  argumento    ExpedienteArgumento @relation(fields: [argumentoId], references: [id], onDelete: Cascade)
  userId       String
  user         User                @relation("ExpedienteComentarios", fields: [userId], references: [id])

  contenido    String

  createdAt    DateTime            @default(now())

  @@index([argumentoId, createdAt])
}

// ─── Noticias Jurídicas ──────────────────────────────────

model NoticiaJuridica {
  id                     String    @id @default(cuid())

  titulo                 String
  resumen                String?
  urlFuente              String    @unique
  fuente                 String
  fuenteNombre           String

  categoria              String?
  rama                   String?

  imagenUrl              String?

  estado                 String    @default("pendiente")
  destacada              Boolean   @default(false)

  fechaPublicacionFuente DateTime?
  fechaRecopilacion      DateTime  @default(now())
  fechaAprobacion        DateTime?

  aprobadaPor            String?
  notasAdmin             String?

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([estado, fechaAprobacion])
  @@index([fuente, fechaRecopilacion])
  @@index([destacada, estado])
}

// ─── Fallo de la Semana ──────────────────────────────────

model FalloDeLaSemana {
  id              String   @id @default(cuid())

  numero          Int      @unique
  titulo          String
  tribunal        String
  rol             String
  fechaFallo      String
  resumen         String
  preguntaGuia    String

  urlFallo        String?
  rama            String
  materias        String?

  fechaInicio     DateTime
  fechaCierre     DateTime
  estado          String   @default("activo")

  mejorAnalisisId String?

  createdAt       DateTime @default(now())

  analisis        AnalisisSentencia[]

  @@index([estado])
}

// ─── Debates Jurídicos ───────────────────────────────────

model DebateJuridico {
  id              String   @id @default(cuid())

  titulo          String
  descripcion     String
  rama            String
  materias        String?

  autor1Id        String
  autor1          User     @relation("DebateAutor1", fields: [autor1Id], references: [id])
  autor1Posicion  String?
  autor1Argumento String?
  autor1Replica   String?

  autor2Id        String?
  autor2          User?    @relation("DebateAutor2", fields: [autor2Id], references: [id])
  autor2Posicion  String?
  autor2Argumento String?
  autor2Replica   String?

  votosAutor1     Int      @default(0)
  votosAutor2     Int      @default(0)

  estado          String   @default("buscando_oponente")

  fechaLimiteArgumentos DateTime?
  fechaLimiteReplicas   DateTime?
  fechaLimiteVotacion   DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  votos           DebateVoto[]

  @@index([estado])
  @@index([createdAt])
}

model DebateVoto {
  id         String         @id @default(cuid())
  debateId   String
  debate     DebateJuridico @relation(fields: [debateId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation("DebateVotos", fields: [userId], references: [id])
  votoPara   String

  createdAt  DateTime       @default(now())

  @@unique([debateId, userId])
}

// ─── Colaboración en Publicaciones ────────────────────────

model ColaboracionInvitacion {
  id              String   @id @default(cuid())
  publicacionId   String
  publicacionTipo String

  invitadoPor     String
  invitadoId      String
  invitado        User     @relation("ColaboracionInvitado", fields: [invitadoId], references: [id])

  estado          String   @default("pendiente")

  createdAt       DateTime @default(now())

  @@unique([publicacionId, invitadoId])
  @@index([invitadoId, estado])
}

// ─── Peer Review ──────────────────────────────────────────

model PeerReview {
  id                String   @id @default(cuid())
  publicacionId     String
  publicacionTipo   String
  autorId           String

  reviewerId        String
  reviewer          User     @relation("ReviewsRealizados", fields: [reviewerId], references: [id])

  estado            String   @default("pendiente")

  claridadScore     Int?
  rigorScore        Int?
  originalidadScore Int?
  comentarioGeneral String?
  sugerencias       String?

  createdAt         DateTime @default(now())
  completedAt       DateTime?

  @@unique([publicacionId, reviewerId])
  @@index([reviewerId, estado])
  @@index([publicacionId])
}
