model EnsayoComuniquese {
  id        String   @id @default(uuid())
  ensayoId  String
  ensayo    Ensayo   @relation(fields: [ensayoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("EnsayoComuniquese", fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([ensayoId, userId])
  @@index([userId])
