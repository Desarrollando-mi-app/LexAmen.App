  createdAt DateTime @default(now())

  @@unique([argumentoId, userId])
}

model ExpedienteComentario {
  id          String              @id @default(cuid())
  argumentoId String
  argumento   ExpedienteArgumento @relation(fields: [argumentoId], references: [id], onDelete: Cascade)
