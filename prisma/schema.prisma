  user      User     @relation("EnsayoGuardados", fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([ensayoId, userId])
  @@index([userId])
}

model EnsayoComuniquese {
  id        String   @id @default(uuid())
  ensayoId  String
  ensayo    Ensayo   @relation(fields: [ensayoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("EnsayoComuniquese", fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([ensayoId, userId])
  @@index([userId])
}

// ─── Columnas de Opinión Jurídica ────────────────────────
// Columnas editoriales — texto libre, no archivo. Más ligeras que Ensayo,
// más largas que Obiter Dictum. Formato editorial de revista.

model ColumnaJuridica {
